{
  "name": "2c-boutique-scaffold-v2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/generate-product-catalog.mjs",
    "prebuild": "node scripts/generate-product-catalog.mjs && node scripts/validate-product-copy.mjs",
    "validate:copy": "node scripts/validate-product-copy.mjs",
    "validate:data": "node scripts/validate-extracted-products.mjs",
    "images:manifest": "node scripts/generate-site-image-manifest.mjs",
    "images:check": "node scripts/check-image-placeholders.mjs",
    "images:prepare": "npm run images:manifest && npm run images:check",
    "images:prune": "node scripts/prune-site-images.mjs",
    "images:prune:remote": "python3 scripts/prune-site-images-r2.py",
    "images:audit": "node scripts/audit-site-images.mjs",
    "images:render": "node scripts/render-site-images.mjs",
    "images:upload": "python3 scripts/upload-site-images-to-r2.py",
    "ops:weekly-summary": "node scripts/generate-weekly-ops-summary.mjs",
    "ops:weekly-plan": "node scripts/generate-weekly-ops-plan.mjs",
    "ops:weekly-review": "node scripts/generate-weekly-ops-review.mjs",
    "ops:weekly-replan": "node scripts/generate-weekly-ops-replan.mjs",
    "ops:qa-sampling": "node scripts/generate-qa-sampling-queue.mjs",
    "ops:publish-gate": "node scripts/evaluate-publish-gate.mjs",
    "validate:ops": "npm run ops:publish-gate",
    "ops:generate": "npm run ops:weekly-summary && npm run ops:weekly-plan && npm run ops:weekly-review && npm run ops:weekly-replan && npm run ops:qa-sampling && npm run ops:publish-gate",
    "ops:cycle": "npm run ops:generate",
    "dev": "astro dev",
    "build": "npm run images:audit && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/sitemap": "^3.7.1",
    "@types/js-yaml": "^4.0.9",
    "astro": "^6.0.8",
    "js-yaml": "^4.1.1",
    "stripe": "^20.4.1"
  }
}
