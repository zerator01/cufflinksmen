---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Order Confirmed" description="Your order has been placed successfully." noindex={true}>
  <section class="checkout-result section">
    <div class="container" style="max-width: 600px; text-align: center; padding: 6rem 1rem;">
      <div class="success-icon">✓</div>
      <h1>Thank You for Your Order</h1>
      <p class="checkout-result__msg">
        Your payment has been received. A confirmation email with tracking details will be sent to you shortly.
      </p>
      <p class="checkout-result__sub">
        Most orders ship within 1–3 business days and arrive within 7–15 business days.
      </p>
      <a href="/products" class="btn btn--primary" style="margin-top: 2rem; display: inline-block;">Continue Browsing</a>
    </div>
  </section>
</BaseLayout>

<style>
  .success-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #000;
    color: #fff;
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-xl);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .checkout-result__msg {
    font-size: 1.1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .checkout-result__sub {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  // Clear cart after successful payment
  localStorage.removeItem('2cjiaoshoujia_cart');
</script>
