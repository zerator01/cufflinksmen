---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import config from '../../lib/config';

export async function getStaticPaths() {
  return config.categories.map((cat: any) => ({
    params: { slug: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const allProducts = await getCollection('products');

// Filter products based on category name matching
const categoryProducts = allProducts
  .filter(p => p.data.category === cat.name)
  .map(entry => ({
    id: entry.id,
    name: entry.data.name,
    price: entry.data.price,
    image: entry.data.image,
    link: `/products/${entry.id}`,
    category: entry.data.category,
  }));

// 1. Generate BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": `https://${config.brand.domain}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Collections",
      "item": `https://${config.brand.domain}/products`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": cat.name,
      "item": `https://${config.brand.domain}/collections/${cat.slug}`
    }
  ]
};

// 2. Generate ItemList Schema (Products in Category)
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": cat.name,
  "description": cat.description,
  "url": `https://${config.brand.domain}/collections/${cat.slug}`,
  "numberOfItems": categoryProducts.length,
  "itemListElement": categoryProducts.map((p, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://${config.brand.domain}${p.link}`,
    "name": p.name
  }))
};

const jsonLd = JSON.stringify([breadcrumbSchema, itemListSchema]);
const seoTitle = `${cat.name} | ${config.brand.name}`;
const defaultImage = cat.image || config.seo.default_image;
---

<BaseLayout title={seoTitle} description={cat.description} image={defaultImage} jsonLd={jsonLd}>
  
  <!-- Minimalist Breadcrumbs -->
  <div class="container container--breadcrumbs">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/products">Collections</a></li>
        <li aria-current="page">{cat.name}</li>
      </ol>
    </nav>
  </div>

  <!-- Monolithic Hero Header -->
  <section class="monolithic-hero">
    <div class="container">
      <h1 class="monolithic-hero__title animate-fade-in-up delay-1">{cat.name}</h1>
      {/* We keep the description below the fold for SEO - only rendering a subtle architectural rule line here */}
      <hr class="monolithic-hero__divider animate-fade-in-up delay-2" />
    </div>
  </section>

  <!-- Product Grid -->
  <section class="section section--minimal-pt">
    <div class="container">
      {categoryProducts.length === 0 ? (
        <div class="empty-state">
          <p>We are currently curating our upcoming collection. Please check back soon.</p>
          <a href="/products" class="btn btn--outline">View All Collections</a>
        </div>
      ) : (
        <div class="product-grid grid grid--3">
          {categoryProducts.map(product => (
            <div class="product-card card card--monolithic" data-price={product.price} data-name={product.name}>
              <div class="product-card__image-wrap">
                <a href={product.link}>
                  <img src={product.image} alt={product.name} class="card__image" loading="lazy" />
                </a>
              </div>
              <div class="card__body card__body--minimal">
                <h3 class="card__title">{product.name}</h3>
                <p class="product-card__price">${product.price.toFixed(2)}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Collection Style Guide & Pairings -->
  <section class="collection-moodboard section--minimal-pt">
    <div class="container container--narrow text-center">
      <p class="section__subtitle">Styling Notes</p>
      <h2 class="moodboard-title">How to Embody {cat.name}</h2>
      <p class="moodboard-text">
        {cat.slug === 'silver-cufflinks-men' && "Silver speaks in understatement. Best paired with dark navy, charcoal, or classic black suiting. It reflects cool, precision machinery and works impeccably in boardroom lighting. For a modern, stark appearance, pair with a crisp white french-cuff shirt."}
        {cat.slug === 'gold-cufflinks-men' && "Gold brings unapologetic warmth and confidence. Pair these with dark brown, olive, or warm grey suiting. The metallic sheen catches warm evening light perfectly, establishing authority. Let the metal be the focal point of the outfit."}
        {cat.slug === 'novelty-cufflinks-men' && "Novelty is for the man who controls his own narrative. Pair these with casual blazers, sports coats, or wear them unexpectedly with formal tuxedos as a conversation starter. The defining accessory that proves you don't take yourself too seriously."}
      </p>
    </div>
  </section>

  <!-- Editorial SEO Block (Gallery Style) -->
  {cat.description && (
    <section class="editorial-seo-section">
      <div class="container">
        <div class="editorial-seo-grid">
          <div class="editorial-seo__image-wrap">
            <img src={cat.image || config.seo.default_image} alt={`About ${cat.name}`} class="editorial-seo__image" loading="lazy" />
          </div>
          <div class="editorial-seo__content">
            <h2 class="editorial-seo__title">About the <br/>{cat.name} Collection</h2>
            <div class="editorial-seo__placard">
              <p class="editorial-seo__text">{cat.description}</p>
              <div class="editorial-seo__meta">
                <span>Curated for {config.brand.name}</span>
                <span class="editorial-seo__line"></span>
                <span>Bridal Editorial</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style is:global>
  /* Base Variables Override for Monolithic feel if needed, but we rely on global.css */
  
  .container--breadcrumbs {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-md);
  }

  .breadcrumbs {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .breadcrumbs li {
    display: flex;
    align-items: center;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: "/";
    margin-left: 0.5rem;
    color: var(--color-border);
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .breadcrumbs a:hover {
    color: var(--color-primary);
  }

  .breadcrumbs li[aria-current="page"] {
    color: var(--color-primary);
    font-weight: 500;
  }

  /* Monolithic Hero */
  .monolithic-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .monolithic-hero__title {
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: var(--color-primary);
    margin: 0 0 var(--space-xl) 0;
    line-height: 1.1;
  }

  .monolithic-hero__divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
    width: 100%;
    opacity: 0.6;
  }

  .section--minimal-pt {
    padding-top: var(--space-xl);
  }

  /* Monolithic Product Card - Overriding standard card for luxury feel */
  .card--monolithic {
    border: none;
    background: transparent;
    transition: transform 0.4s ease;
  }

  .card--monolithic .product-card__image-wrap {
    background-color: var(--color-bg-alt);
    border-radius: 0; /* Brutalist geometry */
    overflow: hidden;
    margin-bottom: var(--space-md);
    position: relative;
    /* Soft bloom shadow on hover */
    transition: box-shadow 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .card--monolithic:hover .product-card__image-wrap {
    box-shadow: 0 20px 40px rgba(10, 10, 10, 0.08); /* Museum lighting effect */
  }

  .card--monolithic .card__image {
    transition: transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .card--monolithic:hover .card__image {
    transform: scale(1.05); /* Slow, cinematic zoom */
  }

  .card__body--minimal {
    text-align: left;
    padding: 0;
  }

  .card__body--minimal .card__title {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  .card__body--minimal .product-card__price {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--color-text-muted);
  }

  .empty-state p {
    margin-bottom: var(--space-lg);
  }

  /* Editorial SEO Section */
  .editorial-seo-section {
    padding: var(--space-4xl) 0;
    margin-top: var(--space-4xl);
    border-top: 1px solid var(--color-border);
  }

  .editorial-seo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .editorial-seo__image-wrap {
    aspect-ratio: 4/5;
    overflow: hidden;
    background-color: var(--color-bg-alt);
  }

  .editorial-seo__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(80%) contrast(1.1); /* Editorial, moody fashion processing */
    transition: filter 1s ease;
  }

  .editorial-seo__image:hover {
    filter: grayscale(0%) contrast(1);
  }

  .editorial-seo__content {
    max-width: 480px;
  }

  .editorial-seo__title {
    font-size: clamp(2rem, 3vw, 2.5rem);
    font-weight: 300;
    color: var(--color-primary);
    margin-bottom: var(--space-2xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .editorial-seo__text {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-weight: 300;
    margin-bottom: var(--space-2xl);
  }

  /* High-end magazine Drop Cap */
  .editorial-seo__text::first-letter {
    float: left;
    font-size: 4rem;
    line-height: 0.8;
    padding-top: 4px;
    padding-right: 8px;
    padding-left: 3px;
    color: var(--color-primary);
    font-family: var(--font-heading); /* Serif if using serif, otherwise just primary */
  }

  .editorial-seo__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
  }

  .editorial-seo__line {
    height: 1px;
    background-color: var(--color-border);
    flex-grow: 1;
  }

  @media (max-width: 768px) {
    .editorial-seo-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    
    .editorial-seo__image-wrap {
      aspect-ratio: 16/9;
    }
  }

  /* Collection Moodboard Styles */
  .container--narrow {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .text-center {
    text-align: center;
  }

  .collection-moodboard {
    margin: var(--space-4xl) 0;
  }

  .moodboard-title {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
    font-weight: 400;
  }

  .moodboard-text {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--color-text);
    font-weight: 300;
  }
</style>
