---
import config from '../lib/config';

const nav = config.scene_navigator;
---

<section class="scene-nav" id="shop-by-neckline">
  <div class="container">
    <div class="scene-nav__header">
      <p class="section__subtitle">Style Guide</p>
      <h2 class="section__title">{nav.title}</h2>
      <p class="section__description">{nav.subtitle}</p>
    </div>
    <div class="scene-nav__grid">
      {nav.items.map((item: any) => (
        <a href={item.link} class="scene-nav__card">
          <div class="scene-nav__icon">
            <span class="scene-nav__neckline">{item.neckline}</span>
          </div>
          <p class="scene-nav__rec">{item.recommendation}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scene-nav {
    padding: var(--space-4xl) 0;
    background: var(--color-bg-alt, #faf9f7);
  }

  .scene-nav__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .scene-nav__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-xl);
    max-width: 960px;
    margin: 0 auto;
  }

  .scene-nav__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-xl) var(--space-lg);
    border-radius: 12px;
    background: white;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .scene-nav__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .scene-nav__icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f5e6d3, #e8d5c0);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .scene-nav__neckline {
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-dark, #1c1917);
    text-align: center;
    line-height: 1.2;
  }

  .scene-nav__rec {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted, #78716c);
    text-align: center;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .scene-nav__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
  }
</style>
