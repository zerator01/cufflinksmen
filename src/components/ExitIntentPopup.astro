---
import config from '../lib/config';

const popup = config.exit_popup;
// If disabled in config, render nothing
if (!popup?.enabled) return;
---

{popup.enabled && (
<div class="exit-modal-overlay" id="exit-modal">
  <div class="exit-modal">
    <div class="exit-modal__image" style={`background-image: url('${popup.image}')`}></div>
    <div class="exit-modal__content">
      <button class="exit-modal__close" id="exit-close" aria-label="Close modal">&times;</button>
      <span class="exit-modal__badge">{popup.badge}</span>
      <h2 class="exit-modal__title">{popup.title}</h2>
      <p class="exit-modal__desc" set:html={popup.description}></p>
      
      <form class="exit-modal__form" id="exit-form">
        <input type="email" placeholder={popup.input_placeholder} required aria-label="Email address" />
        <button type="submit" class="btn btn--primary">{popup.cta_text}</button>
      </form>
      
      <p class="exit-modal__micro">{popup.micro_text}</p>
      <button class="exit-modal__decline" id="exit-decline">{popup.decline_text}</button>
    </div>
  </div>
</div>
)}

<style>
  .exit-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(28, 25, 23, 0.85);
    backdrop-filter: blur(4px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .exit-modal-overlay.show {
    opacity: 1;
    pointer-events: auto;
  }

  .exit-modal {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    max-width: 800px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: translateY(20px) scale(0.95);
    transition: transform var(--transition-base);
  }

  .exit-modal-overlay.show .exit-modal {
    transform: translateY(0) scale(1);
  }

  .exit-modal__image {
    background-size: cover;
    background-position: center;
  }

  .exit-modal__content {
    padding: var(--space-3xl) var(--space-2xl);
    position: relative;
    text-align: center;
  }

  .exit-modal__close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    background: transparent;
    border: none;
    font-size: 1.5rem;
    color: var(--color-text-muted);
    cursor: pointer;
    line-height: 1;
    padding: 0 var(--space-xs);
  }

  .exit-modal__badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 4px 8px;
    background: var(--color-accent);
    color: var(--color-primary);
    border-radius: var(--border-radius-sm);
    margin-bottom: var(--space-md);
  }

  .exit-modal__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    line-height: 1.1;
    margin-bottom: var(--space-sm);
  }

  .exit-modal__desc {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .exit-modal__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .exit-modal__form input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-sm);
    font-family: var(--font-body);
    font-size: 1rem;
    text-align: center;
  }

  .exit-modal__form input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .exit-modal__micro {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
  }

  .exit-modal__decline {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    text-decoration: underline;
    cursor: pointer;
    font-family: var(--font-body);
  }

  .exit-modal__decline:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .exit-modal {
      grid-template-columns: 1fr;
    }
    .exit-modal__image {
      display: none;
    }
    .exit-modal__content {
      padding: var(--space-2xl) var(--space-lg);
    }
    .exit-modal__title {
      font-size: var(--font-size-2xl);
    }
  }
</style>

<script define:vars={{ successText: popup.success_text, mobileDelay: popup.mobile_delay_ms }}>
  let modalShown = false;
  const overlay = document.getElementById('exit-modal');
  const btnClose = document.getElementById('exit-close');
  const btnDecline = document.getElementById('exit-decline');
  const form = document.getElementById('exit-form');

  function openModal() {
    if (modalShown || !overlay) return;
    if (sessionStorage.getItem('exitModalDismissed')) return;
    overlay.classList.add('show');
    modalShown = true;
  }

  function closeModal() {
    if (!overlay) return;
    overlay.classList.remove('show');
    sessionStorage.setItem('exitModalDismissed', 'true');
  }

  document.addEventListener('mouseleave', (e) => {
    if (e.clientY <= 0) openModal();
  });

  setTimeout(() => {
    if (!modalShown && window.innerWidth < 768) openModal();
  }, mobileDelay || 30000);

  if (btnClose) btnClose.addEventListener('click', closeModal);
  if (btnDecline) btnDecline.addEventListener('click', closeModal);

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      if (btn) {
        btn.textContent = successText || "Done! ✓";
        btn.style.background = "var(--color-primary)";
        btn.style.color = "var(--color-white)";
      }
      setTimeout(closeModal, 2500);
    });
  }
</script>
