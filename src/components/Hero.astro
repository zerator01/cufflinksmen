---
import config from '../lib/config';

const hero = config.hero;
---

<section class="page-hero-immersive">
  <!-- Immersive Cinematic 100vw Background -->
  <img src="/images/hero-bg.webp" alt="Site hero background" class="page-hero-immersive__bg" />
  
  <div class="container page-hero-immersive__container">
    <!-- Gridless, Floating Typography Lockup in the Bottom Left -->
    <div class="page-hero-immersive__content">
      <p class="section__subtitle section__subtitle--hero animate-fade-in-up">{config.brand.shipping_banner}</p>
      <h1 class="page-hero-immersive__title animate-fade-in-up delay-1">{hero.headline}</h1>
      <p class="page-hero-immersive__text animate-fade-in-up delay-2">{hero.subheadline}</p>
      <div class="animate-fade-in-up delay-3 hero-action">
        <a href={hero.cta_link} class="btn btn--solid-dark btn--large">{hero.cta_text}</a>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* 
   * Option A: The Immersive Cinematic
   * A 100vw/100vh edge-to-edge photography experience.
   * No grid lines, no glass boxes, just pure typography on imagery.
   */
  .page-hero-immersive {
    position: relative;
    width: 100%;
    /* Accounting for the white header, the hero takes the rest of the height */
    min-height: calc(100vh - var(--header-height, 60px));
    display: flex;
    align-items: flex-end; /* Lockup sits dramatically at the bottom */
    padding-bottom: 8%; /* Spacing from the bottom fold */
    background-color: var(--color-bg);
    overflow: hidden;
  }

  .page-hero-immersive__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    z-index: 1;
    /* Organic cinematic slow-pan */
    transform: scale(1.02);
    transition: transform 16s ease-out;
    opacity: 0.95;
  }

  .page-hero-immersive:hover .page-hero-immersive__bg {
    transform: scale(1.06); 
  }

  /* Text Container */
  .page-hero-immersive__container {
    position: relative;
    z-index: 10;
    width: 100%;
    padding: 0 5%;
  }

  .page-hero-immersive__content {
    max-width: 600px;
    /* We apply extremely subtle light-bloom behind the text to ensure legibility 
       against bright spots on the silk, without creating hard grid lines */
    background: radial-gradient(ellipse at center, rgba(250, 250, 249, 0.6) 0%, rgba(250, 250, 249, 0) 70%);
    padding: var(--space-xl) var(--space-2xl) var(--space-xl) 0;
  }

  /* Cinematic Typography */
  .page-hero-immersive__title {
    font-family: var(--font-heading);
    font-size: clamp(3.2rem, 5.5vw, 5.5rem); /* Slightly larger clamp for dramatic effect */
    color: var(--color-primary); /* Dark off-black (#0A0A0A) */
    line-height: 0.95; /* Pure editorial tightness */
    margin-bottom: var(--space-lg);
    font-weight: 500;
    letter-spacing: -0.04em; /* bespoke logotype feel */
    mix-blend-mode: multiply; /* Natural ink-like absorption into the background */
  }

  .page-hero-immersive__text {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted); /* Dark gray */
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    font-weight: 300;
    max-width: 480px;
  }

  .section__subtitle--hero {
    color: var(--color-primary); /* Swapped from accent gold to sophisticated black */
    margin-bottom: var(--space-md);
    letter-spacing: 0.15em; /* Refined width, readable but elegant */
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .hero-action {
    margin-top: var(--space-md);
  }

  /* Mobile Adjustments */
  @media (max-width: 992px) {
    .page-hero-immersive {
      align-items: center; /* Center on mobile to ensure imagery frames it above and below */
      padding-bottom: 0;
    }

    .page-hero-immersive__bg {
      object-position: 70% 30%; /* Shift focus to pearls on mobile crop */
    }

    .page-hero-immersive__content {
      padding: var(--space-2xl);
      text-align: center;
      margin: 0 auto;
      background: radial-gradient(ellipse at center, rgba(250, 250, 249, 0.8) 0%, rgba(250, 250, 249, 0) 80%);
    }

    .page-hero-immersive__title {
      font-size: var(--font-size-4xl);
    }
    
    .page-hero-immersive__text {
      margin: 0 auto var(--space-xl);
    }
  }
</style>
